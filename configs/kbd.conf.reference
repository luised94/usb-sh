# kbd - knowledge base, syncs zotero bib
local_dir={HOME}/personal_repos/usb-repos/kbd
repo_path=personal_repos/kbd.git
sync_file=/mnt/c/Users/{WINDOWS_USER}/Zotero/zotero_library.bib:{USB_ROOT}/shared/kbd_zotero_library.bib:newer
sync_file={USB_ROOT}/shared/kbd_zotero_library.bib:{LOCAL_DIR}/zotero_library.bib:newer
